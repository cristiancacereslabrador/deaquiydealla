# Copia este archivo a `.env.local` y rellena los valores desde el panel de Supabase (Settings → API).

# URL del proyecto (Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Clave anónima pública (anon public) — solo expón variables NEXT_PUBLIC_* en el cliente.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública del sitio (metadatos / enlaces absolutos). Ejemplo dev:
# NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3280

# SQL de la tabla `pedidos`: ejecuta el fichero `supabase/migrations/001_pedidos.sql` en el SQL Editor de Supabase antes de usar checkout.
